# Environment Variables for Backend
# Copy this file to .env and fill in your actual values

# PostgreSQL Database Configuration (Supabase)
# Format: postgresql://user:password@host:port/database
# Get from Supabase: Project Settings > Database > Connection String (PostgreSQL)
# Direct connection (recommended for long-lived backend servers)
# IMPORTANT: URL-encode special characters in password, e.g. @ becomes %40
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
# If your environment is IPv4-only, use Supabase Session Pooler connection string instead.

# Supabase API Configuration (Optional - for alternative authentication)
# Get from Supabase dashboard: Project Settings > API Keys
# Publishable key (safe to use in browser with RLS)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_ANON_KEY=sb_publishable_your_key_here

# Service Role key (secret - use only on backend)
SUPABASE_SECRET_KEY=sb_secret_your_key_here
SUPABASE_SERVICE_KEY=sb_service_your_key_here

# Supabase URL
SUPABASE_URL=https://your-project.supabase.co

# Grok/Groq API Configuration
# Example GROK_API_URL for Groq OpenAI-compatible endpoint:
# https://api.groq.com/openai/v1/chat/completions
GROK_API_KEY=your_grok_or_groq_api_key_here
GROK_API_URL=https://api.groq.com/openai/v1/chat/completions
GROK_MODEL=llama-3.1-8b-instant

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_LOG_LEVEL=info
